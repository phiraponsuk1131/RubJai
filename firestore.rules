rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        && (!('displayName' in request.resource.data) || (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 100))
        && (!('phone' in request.resource.data) || (request.resource.data.phone is string && request.resource.data.phone.size() <= 30));
      match /transactions/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.type in ['INCOME', 'EXPENSE']
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 200
          && request.resource.data.rawText is string
          && request.resource.data.rawText.size() <= 3000;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
